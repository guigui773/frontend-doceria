rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menu items - public read, authenticated write
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings - public read, authenticated write
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders - authenticated users can read/write their own orders
    match /orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.owner_uid;
      allow create: if request.auth != null;
    }

    // Order items subcollection
    match /orders/{orderId}/items/{itemId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/orders/$(orderId)).data.owner_uid == request.auth.uid;
    }

    // Counters - only authenticated users can update
    match /counters/{document} {
      allow read, write: if request.auth != null;
    }
  }
}